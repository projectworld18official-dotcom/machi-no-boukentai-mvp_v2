{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-level settings for machi-no-boukentai-mvp_v2. Place at <project>/.claude/settings.json. Enables acceptEdits for fast iteration, allows full npm/node/git workflow, but git push/destructive ops still prompt.",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Edit",
      "Write",
      "MultiEdit",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm ci)",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm start)",
      "Bash(npm start *)",
      "Bash(npm build)",
      "Bash(npm build *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(vite *)",
      "Bash(git add *)",
      "Bash(git add)",
      "Bash(git commit *)",
      "Bash(git commit)",
      "Bash(git checkout *)",
      "Bash(git checkout)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git restore *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(type *)",
      "Bash(more *)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(npm uninstall *)",
      "Bash(rm *)",
      "Bash(del *)",
      "Bash(Remove-Item *)"
    ]
  }
}
